{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Polynoia",
  "version": "0.1.2",
  "identifier": "com.polynoia.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @polynoia/web dev",
    "devUrl": "http://127.0.0.1:7788",
    "beforeBuildCommand": "pnpm --filter @polynoia/web build && node ../../scripts/prepare-desktop-server.mjs",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Polynoia",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible",
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob:; connect-src 'self' http: https: ws: wss:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Polynoia multi-agent IM client",
    "longDescription": "Polynoia desktop client — chat with multiple AI coding agents (Claude Code, OpenCode, Codex) in IM style. Same codebase as the web app, native macOS / Windows / Linux window.",
    "resources": [
      "resources/server",
      "resources/bin"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "127.0.0.1"
    }
  }
}
